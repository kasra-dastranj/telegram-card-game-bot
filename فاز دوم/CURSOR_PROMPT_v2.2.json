{
  "project": "TelBattle Phase 2",
  "version": "2.2.0",
  "target_timeline": "30 days",
  "team_size": 2,

  "core_philosophy": {
    "transformation": "از بازی PvP ساده به اکوسیستم کلکسیونی کامل",
    "priorities": [
      "حس ارزش واقعی برای کارت‌ها",
      "پیشرفت بلندمدت (Level & Tier)",
      "اقتصاد متوازن",
      "عمق استراتژیک"
    ],
    "design_principles": [
      "بدون تصادف ناعادلانه در پیشرفت — Fusion کاملاً قطعی است",
      "بدون Claim Burn — کلیم هرگز ناموفق نمی‌شود",
      "Fusion انتخابی — بازیکن کنترل کامل دارد",
      "لیگ فعالیت‌محور — Decay برای همه Tier ها اعمال می‌شود",
      "منصفانه و مهارت‌محور — تمام مسیرهای پیشرفت عادلانه است"
    ]
  },

  "implementation_phases": {
    "week_1": {
      "focus": "Core Systems & Database",
      "tasks": [
        "تغییر schema دیتابیس",
        "سیستم Level & XP",
        "سیستم Tier & TP",
        "کلیم جدید (احتمال برابر + pool management)",
        "بازی 3 راوندی"
      ]
    },
    "week_2": {
      "focus": "Game Mechanics & Economy",
      "tasks": [
        "زمین‌های بازی",
        "تایپ کارت‌ها",
        "Fusion System (انتخابی، قطعی، ۳ کارت)",
        "اقتصاد سکه",
        "شاپ"
      ]
    },
    "week_3": {
      "focus": "Advanced Features & Polish",
      "tasks": [
        "Risk Mode (ساده)",
        "اسکین‌ها",
        "Tier Decay روزانه (با Protection Days)",
        "بهینه‌سازی",
        "تست"
      ]
    },
    "week_4": {
      "focus": "Launch & Monitor",
      "tasks": [
        "پیام همگانی",
        "راه‌اندازی کانال",
        "مانیتور اقتصاد",
        "Balance tuning"
      ]
    }
  },

  "database_changes": {
    "new_tables": [
      {
        "name": "player_progression",
        "columns": {
          "user_id": "INTEGER PRIMARY KEY",
          "level": "INTEGER DEFAULT 1",
          "total_xp": "INTEGER DEFAULT 0",
          "tier_points": "INTEGER DEFAULT 0",
          "last_played_at": "DATETIME",
          "current_tier": "TEXT DEFAULT 'Bronze'"
        },
        "purpose": "ذخیره Level، Tier، و آخرین زمان بازی بازیکن. last_played_at برای محاسبه Decay استفاده می‌شود."
      },
      {
        "name": "card_missions",
        "columns": {
          "user_id": "INTEGER",
          "card_id": "TEXT",
          "mission_type": "TEXT",
          "current_progress": "INTEGER DEFAULT 0",
          "target": "INTEGER",
          "completed": "BOOLEAN DEFAULT 0"
        },
        "purpose": "پیگیری ماموریت‌های کارت برای Legend"
      },
      {
        "name": "player_skins",
        "columns": {
          "user_id": "INTEGER",
          "card_id": "TEXT",
          "skin_id": "TEXT",
          "unlocked": "BOOLEAN DEFAULT 1"
        },
        "purpose": "اسکین‌های unlock شده"
      },
      {
        "name": "active_skins",
        "columns": {
          "user_id": "INTEGER",
          "card_id": "TEXT",
          "skin_id": "TEXT"
        },
        "purpose": "اسکین فعال هر کارت"
      },
      {
        "name": "fusion_log",
        "columns": {
          "id": "INTEGER PRIMARY KEY AUTOINCREMENT",
          "user_id": "INTEGER NOT NULL",
          "fusion_type": "TEXT NOT NULL",
          "consumed_card_1": "TEXT NOT NULL",
          "consumed_card_2": "TEXT NOT NULL",
          "consumed_card_3": "TEXT NOT NULL",
          "upgraded_card_id": "TEXT NOT NULL",
          "result_rarity": "TEXT NOT NULL",
          "timestamp": "DATETIME DEFAULT CURRENT_TIMESTAMP"
        },
        "purpose": "لاگ کامل Fusion برای شفافیت. هر سه کارت مصرفی و کارت انتخاب‌شده ثبت می‌شوند."
      },
      {
        "name": "risk_battles",
        "columns": {
          "fight_id": "TEXT PRIMARY KEY",
          "table_size": "INTEGER",
          "current_pot": "INTEGER",
          "max_pot": "INTEGER",
          "challenger_cards": "TEXT",
          "opponent_cards": "TEXT",
          "bluff_history": "TEXT"
        },
        "purpose": "اطلاعات بازی‌های Risk"
      }
    ],

    "modified_tables": [
      {
        "name": "cards",
        "new_columns": {
          "card_type": "TEXT DEFAULT 'POWER_TYPE'",
          "mission_for_legend": "TEXT"
        },
        "modified_columns": {
          "power": "INTEGER (0-10) not (1-100)",
          "speed": "INTEGER (0-10)",
          "iq": "INTEGER (0-10)",
          "popularity": "INTEGER (0-10)"
        }
      },
      {
        "name": "players",
        "new_columns": {
          "max_hearts": "INTEGER DEFAULT 10",
          "coins": "INTEGER DEFAULT 0",
          "weekly_score": "INTEGER DEFAULT 0",
          "last_mining_claim": "DATETIME"
        }
      },
      {
        "name": "active_fights",
        "new_columns": {
          "arena_type": "TEXT",
          "round_1_winner": "INTEGER",
          "round_2_winner": "INTEGER",
          "round_3_winner": "INTEGER",
          "round_1_stat": "TEXT",
          "round_2_stat": "TEXT",
          "round_3_stat": "TEXT",
          "challenger_card_stats_reduced": "TEXT",
          "opponent_card_stats_reduced": "TEXT"
        }
      }
    ]
  },


          "protection_description": "روزهای بی‌فعالیت بدون از دست دادن TP. بعد از پایان حفاظت، Decay روزانه شروع می‌شود.",

          "algorithm": {
            "step_1": "محاسبه days_inactive = امروز - last_played_at",
            "step_2": "دریافت protection = PROTECTION_DAYS[current_tier]",
            "step_3": "اگر days_inactive <= protection: بازگشت بدون تغییر",
            "step_4": "decay_days = days_inactive - protection",
            "step_5": "raw_decay = decay_days × 30",
            "step_6": "max_decay = current_tp × 0.50",
            "step_7": "actual_decay = min(raw_decay, max_decay)",
            "step_8": "new_tp = max(0, current_tp - actual_decay)",
            "step_9": "به‌روزرسانی Tier بر اساس TP جدید"
          },

